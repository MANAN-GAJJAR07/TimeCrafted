<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".TimeCraftedAdminApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TimeCraftedAdmin"
        tools:targetApi="31"
        tools:replace="android:fullBackupContent">
        
        <!-- Admin Login Activity (Main Entry Point) -->
        <activity
            android:name=".ui.auth.AdminLoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Admin Dashboard -->
        <activity
            android:name=".ui.dashboard.AdminDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />

        <!-- Product Management -->
        <activity
            android:name=".ui.products.AdminProductsActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />
            
        <activity
            android:name=".ui.products.AdminAddEditProductActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />

        <!-- Order Management -->
        <activity
            android:name=".ui.orders.AdminOrdersActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />
            
        <activity
            android:name=".ui.orders.AdminOrderDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />

        <!-- User Management -->
        <activity
            android:name=".ui.users.AdminUsersActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />
            
        <activity
            android:name=".ui.users.AdminAddEditUserActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />

        <!-- Category Management -->
        <activity
            android:name=".ui.categories.AdminCategoriesActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />
            
        <activity
            android:name=".ui.categories.AdminAddEditCategoryActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />

        <!-- Statistics Activity -->
        <activity
            android:name=".ui.statistics.AdminStatisticsActivity"
            android:exported="false"
            android:theme="@style/Theme.TimeCraftedAdmin" />

    </application>

</manifest>
