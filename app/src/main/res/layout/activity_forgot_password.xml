<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/r620xm9g5rcm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FCF9F7">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/retb7sopvv6o"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="179dp"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/r4wnialc7txh"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:src="@drawable/img_forgot"
                    android:scaleType="fitXY"
                    />
                <LinearLayout
                    android:id="@+id/rprd9yidoen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="#FCF9F7"
                    android:padding="16dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/ryrdo8eucjz"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginVertical="12dp"
                        android:layout_marginEnd="24dp"
                        android:src="@drawable/back_arrow"
                        android:scaleType="fitXY"
                        />
                    <TextView
                        android:id="@+id/rua5wm5tzbd"
                        android:textColor="#1C190C"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Forgot Password"
                        />
                </LinearLayout>
                <TextView
                    android:id="@+id/rr4f03mrbul"
                    android:textColor="#1C190C"
                    android:textSize="16sp"
                    android:layout_marginVertical="4dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Enter your email address and we'll send you instructions to reset your password."
                    />
                <EditText
                    android:inputType="text"
                    android:hint="Email"
                    android:id="@+id/r8ilcb8qy4sk"
                    android:textColor="#998E4C"
                    android:textSize="16sp"
                    android:layout_marginVertical="12dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/cr12bf2f2e8"
                    android:paddingVertical="16dp"
                    android:paddingLeft="16dp"
                    android:paddingRight="32dp"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rv28zsvwlwz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/rd1tuu67a8rk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginVertical="12dp"
                    android:background="@drawable/cr12bf2ba0c"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:minHeight="48dp"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:id="@+id/r97cnh0qd11b"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send Reset Instructions"
                        android:textColor="#1C190C"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/ru8nkieuss4d"
                    android:textColor="#998E4C"
                    android:textSize="14sp"
                    android:layout_marginVertical="4dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Remember your password? Login"
                    />
                <LinearLayout
                    android:id="@+id/r5spz7g2907p"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:background="#FCF9F7"
                    android:orientation="vertical">
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
