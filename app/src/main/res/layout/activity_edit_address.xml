<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/backgroundLight"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/rwhvbasgi3hp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/backgroundLight">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/r8594cabo8q7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/backgroundLight"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/romq6fyhpx58"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/rd9duyp6kvs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="@color/backgroundLight"
                        android:padding="16dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/rvdzbgxq6ll"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginVertical="12dp"
                            android:layout_marginEnd="24dp"
                            android:src="@drawable/back_arrow"
                            android:scaleType="fitXY"
                            />
                        <TextView
                            android:id="@+id/r87hplfse2vc"
                            android:textColor="@color/textColor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Edit Address"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r6dgjqkyzito"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/ri4qb8cgbcq9"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Full Name"
                            />
                        <LinearLayout
                            android:id="@+id/rva6ewchitzl"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">
                            <EditText
                                android:id="@+id/fullNameEdit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Full Name"
                                android:textColorHint="@color/innerTextColor"
                                android:paddingStart="15dp"
                                android:backgroundTint="@color/transparent"
                                android:inputType="text"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/phoneNumberLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/phoneNumberLabel"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Mobile Number"
                            />
                        <LinearLayout
                            android:id="@+id/phoneNumberContainer"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">
                            <EditText
                                android:id="@+id/phoneNumberEdit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Enter your mobile number"
                                android:textColorHint="@color/innerTextColor"
                                android:paddingStart="15dp"
                                android:backgroundTint="@color/transparent"
                                android:inputType="phone"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r3qxfa5k6j3b"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rnbugyv7f2dt"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Street Address Line 1"
                            />
                        <LinearLayout
                            android:id="@+id/rqljzkwn293"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">
                            <EditText
                                android:id="@+id/addressLine1Edit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Street Address"
                                android:paddingStart="15dp"
                                android:textColorHint="@color/innerTextColor"
                                android:backgroundTint="@color/transparent"
                                android:inputType="text"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r470aqj8mxt5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rl4kj84lzbd"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Street Address Line 2 (Optional)"
                            />
                        <LinearLayout
                            android:id="@+id/r2imizjkhp1d"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">
                            <EditText
                                android:id="@+id/addressLine2Edit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Street Address"
                                android:textColorHint="@color/innerTextColor"
                                android:paddingStart="15dp"
                                android:backgroundTint="@color/transparent"
                                android:inputType="text"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/ra3ga0nvci9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rh7xmjalgo1h"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="City"
                            />
                        <LinearLayout
                            android:id="@+id/rpt6idi6y7ec"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/cityEdit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:textColorHint="@color/innerTextColor"
                                android:hint="City"
                                android:inputType="text"
                                android:paddingStart="15dp" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r4unqahmms85"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rdf1svw6wjy"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="State/Province"
                            />
                        <LinearLayout
                            android:id="@+id/rsqr4mkwklc"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/stateEdit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:textColorHint="@color/innerTextColor"
                                android:hint="State/Province"
                                android:paddingStart="15dp"
                                android:inputType="text" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r6609uxk1qy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rrn26l2g17bq"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Zip/Postal Code"
                            />
                        <LinearLayout
                            android:id="@+id/rgbhzcd6vwtm"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">
                            <EditText
                                android:id="@+id/zipCodeEdit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Zip/Postal Code"
                                android:textColorHint="@color/innerTextColor"
                                android:paddingStart="15dp"
                                android:backgroundTint="@color/transparent"
                                android:inputType="numberDecimal"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rjeesj5eipr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/r5k1iksypx7q"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Country"
                            />
                        <LinearLayout
                            android:id="@+id/r9ktx2hjpv2"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/cr12bf2f2e8"
                            android:orientation="vertical">
                            <EditText
                                android:id="@+id/countryEdit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Country"
                                android:paddingStart="15dp"
                                android:backgroundTint="@color/transparent"
                                android:textColorHint="@color/innerTextColor"
                                android:inputType="text"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r6fr00lr70kc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="@color/backgroundLight"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal">

                        <Switch
                            android:id="@+id/switch1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColorHint="@color/textColor"
                            android:minHeight="48dp"
                            android:text="Set as Default Address"
                            tools:ignore="UseSwitchCompatOrMaterialXml" />


                    </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r3ftvr8969f8"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/rat5oln817eo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_horizontal"
                            android:minHeight="48dp"
                            android:padding="0.5dp"
                            android:orientation="vertical">

                            <Button
                                android:id="@+id/rj5cn2mp6fh"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cancel"
                                android:backgroundTint="@color/transparent"
                                android:textColor="@color/textColor"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            />

                        <LinearLayout
                            android:id="@+id/reytbeiho1f8"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2ba0c"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_horizontal"
                            android:minHeight="48dp"
                            android:padding="0.5dp"
                            android:orientation="vertical">

                            <Button
                                android:id="@+id/r3ygx9ogp9xs"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="Save Changes"
                                android:textColor="@color/textColor"
                                android:backgroundTint="@color/transparent"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/re465tunrii9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:paddingVertical="21dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/rln6vvd12148"
                            android:layout_width="150dp"
                            android:layout_height="48dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">
                            <Button
                                android:id="@+id/r63e71vxihl"
                                android:textColor="@color/textColor"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_height="match_parent"
                                android:layout_width="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:text="Delete Address"
                                />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rfv7uz7tvwnd"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:background="@color/backgroundLight"
                    android:orientation="vertical">
                </LinearLayout>
            </LinearLayout>
    </ScrollView>
</LinearLayout>
