<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".ui.product.productDetail">

    <!-- Top AppBar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        app:title="Product Details"
        app:titleTextColor="@android:color/black"
        app:navigationIcon="@drawable/back_arrow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Main scrollable content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Product Image centered -->
            <ImageView
                android:id="@+id/productImage"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:background="@null"
                android:contentDescription="product Img"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/product_img" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Prestige Chronograph"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Short paragraph description -->
            <TextView
                android:id="@+id/tvShortDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="A timeless piece of craftsmanship, the Prestige Chronograph combines elegance with precision. Its intricate design and durable construction make it a perfect accessory for any occasion."
                android:textColor="#6b6b6b"
                android:textSize="13.5sp" />

            <!-- Specifications Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpecs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:padding="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSpecsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Specifications"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- two-column grid-like specs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/specLabel1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Movement"
                                android:textColor="#6b6b6b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/specValue1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Automatic"
                                android:textColor="@android:color/black"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/specLabel2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Strap Material"
                                android:textColor="#6b6b6b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/specValue2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Leather"
                                android:textColor="@android:color/black"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/specLabel3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Diameter"
                                android:textColor="#6b6b6b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/specValue3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="42mm"
                                android:textColor="@android:color/black"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/specLabel4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Case Material"
                                android:textColor="#6b6b6b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/specValue4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Stainless Steel"
                                android:textColor="@android:color/black"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/specLabel5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Water Resistance"
                                android:textColor="#6b6b6b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/specValue5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="100m"
                                android:textColor="@android:color/black"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/specLabel6"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Crystal"
                                android:textColor="#6b6b6b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/specValue6"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Sapphire"
                                android:textColor="@android:color/black"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Price + CTA -->
            <LinearLayout
                android:id="@+id/priceCtaRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="$1,250"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="0.01dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr12bf2ba0c"
                        android:layout_marginEnd="35dp"
                        android:padding="0.01dp">

                        <Button
                            android:id="@+id/btnAddToCart"
                            android:layout_width="160dp"
                            android:layout_height="48dp"
                            android:backgroundTint="@color/transparent"
                            android:minWidth="120dp"
                            android:text="Add to Cart"
                            android:textColor="@color/textColor"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr12bf2f2e8"
                        android:padding="0.01dp">
                        <Button
                            android:id="@+id/btnWishlist"
                            android:layout_width="180dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:text="Add to Wishlist"
                            android:textColor="@color/textColor"
                            android:background="@color/transparent" />

                    </LinearLayout>



                </LinearLayout>

            </LinearLayout>

            <!-- Reviews header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvReviewsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Customer Reviews"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvReviewsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120 reviews"
                    android:textColor="#6b6b6b"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Rating summary row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAverageRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.5"
                        android:textColor="@android:color/black"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <RatingBar
                        android:id="@+id/ratingBar"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:rating="4.5" />
                </LinearLayout>

                <!-- Simple star-distribution placeholder -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- 5 rows for 5->1 star percentages -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="5"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="40%"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Repeat rows (4,3,2,1) - you can populate programmatically -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="4"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="30%"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="20%"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="2"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="5%"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="5%"
                            android:textColor="#6b6b6b"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Sample review items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <!-- Review 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="60dp">
                        <ImageView
                            android:id="@+id/reviewerAvatar1"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="review"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_profile" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/reviewerName1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ethan Carter"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <RatingBar
                            android:id="@+id/reviewerRating1"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:rating="5" />

                        <TextView
                            android:id="@+id/reviewerComment1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Absolutely stunning watch! The craftsmanship is impeccable."
                            android:textColor="#6b6b6b"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE" />

                <!-- Review 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="60dp">
                        <ImageView
                            android:id="@+id/reviewerAvatar2"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="review"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_profile" />
                    </androidx.cardview.widget.CardView>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/reviewerName2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sophia Bennett"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <RatingBar
                            android:id="@+id/reviewerRating2"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:rating="4" />

                        <TextView
                            android:id="@+id/reviewerComment2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Beautiful watch with a classic design."
                            android:textColor="#6b6b6b"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Related Products header -->
            <TextView
                android:id="@+id/tvRelatedTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Related Products"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/relatedProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:visibility="gone" />

            <!-- Horizontal RecyclerView for related products -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRelatedProducts"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:overScrollMode="never"
                android:scrollbars="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
