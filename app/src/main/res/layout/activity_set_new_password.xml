<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FCF9F7"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="40dp">
    <ScrollView
        android:id="@+id/rotwacbnx2v9"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FCF9F7">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rq1nlp8h5tj"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="398dp"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/rwt255wjb16i"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:background="#FCF9F7"
                    android:paddingVertical="16dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/r7uhgviqlde2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginVertical="12dp"
                        android:layout_marginStart="24dp"
                        android:src="@drawable/back_arrow"
                        android:scaleType="fitXY"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/rvvgzlo97j9n"
                            android:textColor="#1C190C"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Set New Password"
                            />
                        <LinearLayout
                            android:id="@+id/r02cqlkx9qham"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:orientation="vertical">
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/r5y2vfu1ap1u"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/r7wvljiy8ja"
                        android:textColor="#1C190C"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="New Password"
                        />
                    <EditText
                        android:inputType="text"
                        android:hint="Enter  new password"
                        android:id="@+id/ry9k91e8rys"
                        android:textColor="#998E4C"
                        android:textSize="16sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr12bf2f2e8"
                        android:paddingVertical="16dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="32dp"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rb8j9bk58shq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/ryz6e69si0yf"
                        android:textColor="#1C190C"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Confirm New Password"
                        />
                    <EditText
                        android:inputType="text"
                        android:hint="Re-enter  new password"
                        android:id="@+id/rokmebo8pjkt"
                        android:textColor="#998E4C"
                        android:textSize="16sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr12bf2f2e8"
                        android:paddingVertical="16dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="32dp"
                        />
                </LinearLayout>
                <TextView
                    android:id="@+id/rc0hpaeya4ai"
                    android:textColor="#998E4C"
                    android:textSize="14sp"
                    android:layout_marginVertical="4dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:text="Password must be at least 8 characters long and include a mix of letters, numbers, and symbols."
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rgl2ae0jgh7q"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/refb1ymljpfc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginVertical="12dp"
                    android:background="@drawable/cr12bf2ba0c"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:minHeight="48dp"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:id="@+id/r8y263wjte3t"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set Password"
                        android:textColor="#1C190C"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rgbujt3jvxlu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FCF9F7"
                    android:orientation="vertical"></LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
