<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/rv6sz403h0j"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rscppoluygpc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="#FFFFFF"
                android:paddingVertical="16dp"
                android:paddingLeft="64dp"
                android:paddingRight="16dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/r5sxt1szs2l5"
                    android:textColor="#161611"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Watch Store"
                    />
                <LinearLayout
                    android:id="@+id/rqtwg7982sd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:paddingVertical="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rxjntrvr5b09"
                        android:textColor="#9C8F5C"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Login"
                        />
                </LinearLayout>
            </LinearLayout>
            <ImageView
                android:id="@+id/rpuft8ksda09"
                android:layout_width="match_parent"
                android:layout_height="262dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitXY"
                />
            <LinearLayout
                android:id="@+id/rm87dvsh8an"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/re2s89mj7d9"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tl8bl8bf4f4ef"
                    android:paddingVertical="12dp"
                    android:paddingLeft="16dp"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/ricqu2j7vxeb"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@mipmap/ic_launcher"
                        android:scaleType="fitXY"
                        />
                </LinearLayout>
                <EditText
                    android:inputType="text"
                    android:hint="Search  for watches"
                    android:id="@+id/rpl9ob5km5xn"
                    android:textColor="#898260"
                    android:textSize="16sp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/tr8br8bf4f4ef"
                    android:paddingVertical="12dp"
                    android:paddingLeft="8dp"
                    android:paddingRight="16dp"
                    />
            </LinearLayout>
            <ImageView
                android:id="@+id/rl4exbha8b9c"
                android:layout_width="match_parent"
                android:layout_height="218dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitXY"
                />
            <TextView
                android:id="@+id/r3fedmvyzcbv"
                android:textColor="#161611"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="36dp"
                android:layout_marginStart="16dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="New Arrivals"
                />
            <RelativeLayout
                android:id="@+id/rptva7qjlvz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingLeft="16dp"
                    android:orientation="horizontal">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/rog8cyvw78ue"
                        app:shapeAppearanceOverlay="@style/cr8"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="12dp"
                        android:src="@mipmap/ic_launcher"
                        android:scaleType="fitXY"
                        />
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/r4ukofewigzj"
                        app:shapeAppearanceOverlay="@style/cr8"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="12dp"
                        android:src="@mipmap/ic_launcher"
                        android:scaleType="fitXY"
                        />
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/r8lvmmf27tl5"
                        app:shapeAppearanceOverlay="@style/cr8"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:src="@mipmap/ic_launcher"
                        android:scaleType="fitXY"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/r4pjibd8yw9p"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="0dp"
                    android:layout_alignParentBottom="true"
                    android:layout_width="390dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="#FFFFFF"
                    android:paddingTop="9dp"
                    android:paddingBottom="12dp"
                    android:paddingLeft="16dp"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:id="@+id/rvav0a6k26a"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:background="@drawable/cr27"
                        android:paddingVertical="4dp"
                        android:paddingHorizontal="24dp"
                        android:layout_marginEnd="34dp"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/r6aap9d0r83g"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginBottom="8dp"
                            android:src="@mipmap/ic_launcher"
                            android:scaleType="fitXY"
                            />
                        <TextView
                            android:id="@+id/rj49ra7cv2d"
                            android:textColor="#161611"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Home"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/ruqnj1hg0wpm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:layout_marginEnd="36dp"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/r8lqxqst9gtf"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginBottom="8dp"
                            android:src="@mipmap/ic_launcher"
                            android:scaleType="fitXY"
                            />
                        <TextView
                            android:id="@+id/r5g9vr4b1pyu"
                            android:textColor="#898260"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Shop"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rxqpgoubqjq"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:paddingVertical="4dp"
                        android:paddingHorizontal="18dp"
                        android:layout_marginEnd="30dp"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/rdec7lqjyzev"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginBottom="8dp"
                            android:src="@mipmap/ic_launcher"
                            android:scaleType="fitXY"
                            />
                        <TextView
                            android:id="@+id/r9h4dqsttyxe"
                            android:textColor="#898260"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Wishlist"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rudvx9n7hpt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/r062y06iy0xgn"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginBottom="8dp"
                            android:src="@mipmap/ic_launcher"
                            android:scaleType="fitXY"
                            />
                        <TextView
                            android:id="@+id/rjb4vx2cn63c"
                            android:textColor="#898260"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Profile"
                            />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
