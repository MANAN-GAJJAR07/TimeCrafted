<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FCF9F7"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.profile.orderHistory">
    <ScrollView
        android:id="@+id/rjy5cbraz3e"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FCF9F7">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rf0qoaxhr6ds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FCF9F7"
                android:paddingBottom="328dp"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/rrg549v9zes9"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="#FCF9F7"
                    android:padding="16dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/backBtn"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginVertical="12dp"
                        android:layout_marginStart="24dp"
                        android:src="@drawable/back_arrow"
                        android:scaleType="fitXY"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/rzz8om95i15p"
                            android:textColor="#1C190C"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Order History"
                            />
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="1dp"/>
                    </LinearLayout>

                </LinearLayout>
                <!-- RecyclerView for orders -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOrderHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:clipToPadding="false"/>

                <!-- Empty state -->
                <TextView
                    android:id="@+id/emptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No orders yet"
                    android:textAlignment="center"
                    android:textColor="@color/innerTextColor"
                    android:padding="32dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
