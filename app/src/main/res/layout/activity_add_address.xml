<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/backgroundLight"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.profile.addAddress">
    <ScrollView
        android:id="@+id/r18aqbxrfr33"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/backgroundLight">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rpyybn534f3i"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/backgroundLight"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/rypco9o2vi3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/rvtudg32fwq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="@color/backgroundLight"
                        android:padding="16dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/backBtn"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginVertical="12dp"
                            android:layout_marginEnd="24dp"
                            android:src="@drawable/back_arrow"
                            android:scaleType="fitXY"
                            />
                        <TextView
                            android:id="@+id/rj78udg5tczg"
                            android:textColor="@color/textColor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Add Address"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rxo72l8gg959"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/r348ltje6eca"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Full Name"
                            />
                        <EditText
                            android:inputType="text"
                            android:hint="Enter  your full name"
                            android:id="@+id/r0rz0yiiopp6h"
                            android:textColorHint="@color/innerTextColor"
                            android:textSize="16sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:paddingVertical="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="32dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/phoneNumberLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/phoneNumberLabel"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Mobile Number"
                            />
                        <EditText
                            android:inputType="phone"
                            android:hint="Enter your mobile number"
                            android:id="@+id/phoneNumberEdit"
                            android:textColorHint="@color/innerTextColor"
                            android:textSize="16sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:paddingVertical="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="32dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/ro4zpmiet6sl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/r4u18uveb5no"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Street Address Line 1"
                            />
                        <EditText
                            android:inputType="text"
                            android:hint="Enter  street address"
                            android:id="@+id/rlver2i7dhy"
                            android:textColorHint="@color/innerTextColor"
                            android:textSize="16sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:paddingVertical="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="32dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rxkclhsdc4r"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rpk3zf6lbadj"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Street Address Line 2 (Optional)"
                            />
                        <EditText
                            android:inputType="text"
                            android:hint="Apt,  suite, unit, etc. (optional)"
                            android:id="@+id/r3c9ej87dheb"
                            android:textColorHint="@color/innerTextColor"
                            android:textSize="16sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:paddingVertical="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="32dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r8hdbw7nt0d6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rxvws037t7k"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="City"
                            />
                        <EditText
                            android:inputType="text"
                            android:hint="Enter  city"
                            android:id="@+id/r5clnwkvwiem"
                            android:textColorHint="@color/innerTextColor"
                            android:textSize="16sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:paddingVertical="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="32dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rzgx8y196tr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/r6zdvjaygsgx"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="State/Province"
                            />
                        <EditText
                            android:inputType="text"
                            android:hint="Enter  state or province"
                            android:id="@+id/r26b34o1nxfc"
                            android:textColorHint="@color/innerTextColor"
                            android:textSize="16sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:paddingVertical="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="32dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rqjddfqp1vni"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rsgfgr118hdl"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Zip/Postal Code"
                            />
                        <EditText
                            android:inputType="text"
                            android:hint="Enter  zip or postal code"
                            android:id="@+id/rawe6b9z6cg7"
                            android:textColorHint="@color/innerTextColor"
                            android:textSize="16sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr12bf2f2e8"
                            android:paddingVertical="16dp"
                            android:paddingLeft="16dp"
                            android:paddingRight="32dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r5brqal2tyw2"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rpqpvx8d40y"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/rmgxcs7zy53d"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:id="@+id/ryba9iosv999"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:background="@drawable/cr12bf2f2e8"
                            android:layout_marginEnd="110dp"
                            android:orientation="vertical">
                            <Button
                                android:id="@+id/cancelBtn"
                                android:textColor="@color/textColor"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:backgroundTint="@color/transparent"
                                android:layout_height="match_parent"
                                android:layout_width="match_parent"
                                android:text="Cancel"
                                />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rqxb81l042eb"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:background="@drawable/cr12bf2ba0c"
                            android:orientation="vertical">
                            <Button
                                android:id="@+id/saveAddressBtn"
                                android:textColor="@color/textColor"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_height="match_parent"
                                android:layout_width="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:text="Save Address"
                                />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rwkk26s74jq"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:background="@color/backgroundLight"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
