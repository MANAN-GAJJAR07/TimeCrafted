<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FCF9F7"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/rj4elcc6dmg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FCF9F7">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/r3rw2qsahm9v"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FCF9F7"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/r64lmefn5uia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="464dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/r18b4euqb4nq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="#FCF9F7"
                        android:padding="16dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/rleh7zzj9my"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginVertical="12dp"
                            android:layout_marginStart="24dp"
                            android:src="@drawable/back_arrow"
                            android:scaleType="fitXY"
                            />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/rjrkdzzbxbpa"
                                android:textColor="#1C190C"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Address"
                                />
                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/r2j2frocap48"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="#FCF9F7"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:id="@+id/r8k2u2y2r3i"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:layout_marginEnd="12dp"
                            android:orientation="horizontal">
                            <LinearLayout
                                android:id="@+id/rzajdjtefxp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/cr12bf2f2e8"
                                android:padding="12dp"
                                android:layout_marginEnd="16dp"
                                android:contentDescription="home icon"
                                android:clickable="true"
                                android:focusable="true"
                                android:orientation="vertical">
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/rwhtxb2idev"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/home"
                                    android:scaleType="fitXY"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/rkarvayohftn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:id="@+id/ra3cnk4o67rl"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical">
                                    <TextView
                                        android:id="@+id/rnt31q2dy8p7"
                                        android:textColor="#1C190C"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:layout_height="wrap_content"
                                        android:layout_width="wrap_content"
                                        android:text="Home"
                                        />
                                </LinearLayout>
                                <TextView
                                    android:id="@+id/r7by45vvyx9o"
                                    android:textColor="#998E4C"
                                    android:textSize="14sp"
                                    android:layout_marginEnd="27dp"
                                    android:layout_height="wrap_content"
                                    android:layout_width="wrap_content"
                                    android:text="789 Pine Lane"
                                    />
                            </LinearLayout>
                        </LinearLayout>
                        <ImageView
                            android:id="@+id/rx33wk55f09"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_margin="2dp"
                            android:src="@drawable/edit"
                            android:scaleType="fitXY"
                            />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/r13m0u1bxp6rd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rrmfab8gkhh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginVertical="12dp"
                        android:background="@drawable/cr12bf2ba0c"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_horizontal"
                        android:minHeight="48dp"
                        android:orientation="vertical"
                        android:paddingVertical="12dp">

                        <LinearLayout
                            android:id="@+id/rpu649yrhuaf"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingBottom="1dp">

                            <TextView
                                android:id="@+id/r87t6ga5bavi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Address"
                                android:textColor="#1C190C"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rndg8t2gw1x"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:background="#FCF9F7"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
