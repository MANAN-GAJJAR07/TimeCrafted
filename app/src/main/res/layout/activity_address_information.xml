<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/backgroundLight"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.profile.addressInformation">
    <ScrollView
        android:id="@+id/rj4elcc6dmg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/backgroundLight">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/r3rw2qsahm9v"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/backgroundLight"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/r64lmefn5uia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="464dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/r18b4euqb4nq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="@color/backgroundLight"
                        android:padding="16dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/backBtn"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginVertical="12dp"
                            android:layout_marginStart="24dp"
                            android:src="@drawable/back_arrow"
                            android:scaleType="fitXY"
                            />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/rjrkdzzbxbpa"
                                android:textColor="@color/textColor"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Address"
                                />
                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- RecyclerView for addresses -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAddresses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:clipToPadding="false"/>

                    <!-- Empty state -->
                    <TextView
                        android:id="@+id/emptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No addresses added yet"
                        android:textAlignment="center"
                        android:textColor="@color/innerTextColor"
                        android:padding="32dp"
                        android:visibility="gone"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/r13m0u1bxp6rd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/addAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginVertical="12dp"
                        android:background="@drawable/cr12bf2ba0c"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_horizontal"
                        android:minHeight="48dp"
                        android:orientation="vertical"
                        android:paddingVertical="12dp">

                        <LinearLayout
                            android:id="@+id/rpu649yrhuaf"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingBottom="1dp">

                            <TextView
                                android:id="@+id/r87t6ga5bavi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Address"
                                android:textColor="@color/textColor"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rndg8t2gw1x"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:background="@color/backgroundLight"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
