<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/rst5rtpvgedd"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/r955l9os5j8g"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FCF9F7"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/rcnqqxvq2ceb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/rr7vxp6n3fih"
                        android:layout_width="match_parent"
                        android:layout_height="320dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_register" />

                    <LinearLayout
                        android:id="@+id/rbjn8x2muldc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="#FCF9F7"
                        android:padding="16dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/registerBack"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginVertical="12dp"
                            android:layout_marginEnd="24dp"
                            android:src="@drawable/back_arrow"
                            android:scaleType="fitXY"
                            />
                        <TextView
                            android:id="@+id/rnvfuf3x3g5"
                            android:textColor="@color/textColor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Register"
                            />
                    </LinearLayout>
                    <EditText
                        android:inputType="text"
                        android:hint="Full  Name"
                        android:id="@+id/rgh2sfydx8s7"
                        android:textColor="#998E4C"
                        android:textSize="16sp"
                        android:layout_marginVertical="12dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr12bf2f2e8"
                        android:paddingVertical="16dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="32dp"
                        />
                    <EditText
                        android:inputType="text"
                        android:hint="Email"
                        android:id="@+id/rp0bu1oqe2ca"
                        android:textColor="#998E4C"
                        android:textSize="16sp"
                        android:layout_marginVertical="12dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr12bf2f2e8"
                        android:paddingVertical="16dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="32dp"
                        />
                    <EditText
                        android:inputType="text"
                        android:hint="Password"
                        android:id="@+id/r71sb4nktogh"
                        android:textColor="#998E4C"
                        android:textSize="16sp"
                        android:layout_marginVertical="12dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr12bf2f2e8"
                        android:paddingVertical="16dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="32dp"
                        />

                    <LinearLayout
                        android:id="@+id/ren6fnrhdad4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginVertical="12dp"
                        android:background="@drawable/cr12bf2ba0c"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_horizontal"
                        android:minHeight="48dp"
                        android:orientation="vertical"
                        android:paddingVertical="1dp">

                        <Button
                            android:id="@+id/btnRegister"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="@string/register"
                            android:textColor="@color/textColor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:background="@color/transparent"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/ru13wmpt7i9c"
                        android:textColor="#9B8749"
                        android:textSize="14sp"
                        android:layout_marginVertical="4dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Already have an account? Log in"
                        />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
