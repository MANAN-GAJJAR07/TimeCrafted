<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:background="#FCF9F7"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="40dp"
    >
    <ScrollView
        android:id="@+id/rizbsmo77oso"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rg49xw18780m"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/rdpmqh05g7dw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="380dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/rn1to462a6rf"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingVertical="16dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/r29pv7v7wdh2"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginVertical="12dp"
                            android:layout_marginStart="24dp"
                            android:src="@drawable/back_arrow"
                            android:scaleType="fitXY"
                            />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/rpx4zkjzza4e"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verify Email"
                                android:textColor="#1C190C"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="24dp"></LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                    <TextView
                        android:id="@+id/rh9gynl7b6hq"
                        android:textColor="#1C190C"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Enter OTP"
                        />
                    <TextView
                        android:id="@+id/rs5ohs2i3dj"
                        android:textColor="#1C190C"
                        android:textSize="16sp"
                        android:layout_marginVertical="4dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="We've sent a One-Time Password (OTP) to your email address. Please enter it below to verify your email."
                        />
                    <LinearLayout
                        android:id="@+id/r205rbe955kz"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="11dp"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:id="@+id/ru8kdeex43g8"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/otp_box"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:inputType="number"
                                tools:ignore="SpeakableTextPresentCheck" />

                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rk04njnq457r"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/otp_box"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:inputType="number"
                                tools:ignore="SpeakableTextPresentCheck" />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rcq1dbverjgo"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/otp_box"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:inputType="number"
                                tools:ignore="SpeakableTextPresentCheck" />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rnqv5h7urqv"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/otp_box"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:inputType="number"
                                tools:ignore="SpeakableTextPresentCheck" />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/r638ruf40dsc"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/otp_box"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:inputType="number"
                                tools:ignore="SpeakableTextPresentCheck" />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rnmozqmweu0g"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/otp_box"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:backgroundTint="@color/transparent"
                                android:inputType="number"
                                tools:ignore="SpeakableTextPresentCheck" />
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/r818y9718ns"
                        android:textColor="#998E4C"
                        android:textSize="14sp"
                        android:layout_marginVertical="4dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="OTP valid for 60 seconds"
                        />
                    <TextView
                        android:id="@+id/rrtr3zs5gbk"
                        android:textColor="#998E4C"
                        android:textSize="14sp"
                        android:layout_marginVertical="4dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Resend OTP"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rp3by8djx66"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/rur2p2dwjiqs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:background="@drawable/cr12bf2ba0c"
                        android:paddingVertical="1dp"
                        android:layout_marginVertical="12dp"
                        android:layout_marginHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">
                        <Button
                            android:id="@+id/rkg8sc07hofm"
                            android:textColor="#1C190C"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_height="match_parent"
                            android:layout_width="match_parent"
                            android:backgroundTint="@color/transparent"
                            android:text="Verify"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rt1561v3krod"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:background="#FCF9F7"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
